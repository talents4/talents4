# ─── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Max tokens for classifier call (keep low — JSON only)
GEMINI_CLASSIFIER_MAX_TOKENS=512
# Max tokens for final answer
GEMINI_ANSWER_MAX_TOKENS=1024
# Timeout for each Gemini call in ms
GEMINI_TIMEOUT_MS=20000

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Chat config ───────────────────────────────────────────────────────────────
# How many recent messages to include in context
CHAT_RECENT_MESSAGES=6
# Trigger summarisation when session exceeds this many messages
CHAT_SUMMARISE_AFTER=12
# Max input length in characters
CHAT_MAX_MESSAGE_LENGTH=4000
# Rate limit: max messages per minute per session
CHAT_RATE_LIMIT_PER_MIN=20

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=T4 Assistant
